# Local defaults
HERMES_HOME=/opt/data
HERMES_MODEL=gpt-5.4-mini
HERMES_TAIL_FILE_LOGS=true

# Azure deployment
RESOURCE_GROUP=rg-Urbanquest
LOCATION=swedencentral
CONTAINERAPP_ENV=hermes-env
CONTAINERAPP_NAME=hermes-agent
ACR_NAME=urbanquesthermesacr
ACR_PULL_IDENTITY=hermes-acr-pull
STORAGE_ACCOUNT=urbanquesthermesst
FILE_SHARE=hermes
HERMES_SKIP_IMAGE_BUILD=false
AZURE_AI_RESOURCE_GROUP=rg-Urbanquest
AZURE_AI_RESOURCE_NAME=urbanquest-resource

# Azure OpenAI / Azure AI Foundry
# Use the OpenAI-compatible v1 endpoint, for example:
# https://<resource>.openai.azure.com/openai/v1
# Leave these empty to let scripts/deploy-azure.sh read them from Azure AI.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_BASE_URL=

# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_ALLOWED_USERS=U06JF46Q57F

# Optional default channel for cron/scheduled messages
SLACK_HOME_CHANNEL=
SLACK_HOME_CHANNEL_NAME=

# Optional Google Workspace credentials.
# Generate these with scripts/google-workspace-auth.sh; files stay local and ignored.
GOOGLE_CLIENT_SECRET_FILE=.secrets/google-workspace/google_client_secret.json
GOOGLE_TOKEN_FILE=.secrets/google-workspace/google_token.json

# Optional Composio Connect MCP.
# Get this from https://dashboard.composio.dev.
COMPOSIO_API_KEY=

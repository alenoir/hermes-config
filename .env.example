# Local defaults
OPENCLAW_VERSION=2026.5.7
OPENCLAW_CONFIG_PATH=/root/.openclaw/openclaw.json
OPENCLAW_STATE_DIR=/root/.openclaw
OPENCLAW_GATEWAY_TOKEN=

# Azure deployment
RESOURCE_GROUP=rg-Urbanquest
LOCATION=swedencentral
CONTAINERAPP_ENV=hermes-env
CONTAINERAPP_NAME=hermes-agent
ACR_NAME=urbanquesthermesacr
ACR_PULL_IDENTITY=hermes-acr-pull
STORAGE_ACCOUNT=urbanquesthermesst
FILE_SHARE=hermes
OPENCLAW_SKIP_IMAGE_BUILD=false
OPENCLAW_UPLOAD_LOCAL_STATE=false

# Slack Socket Mode
SLACK_BOT_TOKEN=xoxb-
SLACK_APP_TOKEN=xapp-
SLACK_ALLOWED_USERS=U06JF46Q57F

# Composio Connect MCP
COMPOSIO_API_KEY=

# Optional direct OpenAI API fallback. GPT Pro/Codex OAuth is stored in data/
# after scripts/openai-codex-auth.sh and can be uploaded with
# OPENCLAW_UPLOAD_LOCAL_STATE=true ./scripts/deploy-azure.sh.
OPENAI_API_KEY=
